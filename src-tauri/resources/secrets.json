{
  "version": "1.0.0",
  "patterns": [
    {
      "name": "AWS Access Key ID",
      "pattern": "(?i)(AKIA[0-9A-Z]{16})",
      "severity": 5
    },
    {
      "name": "AWS Secret Access Key",
      "pattern": "(?i)aws_secret_access_key\\s*[=:]\\s*['\"]?([A-Za-z0-9/+=]{40})['\"]?",
      "severity": 5
    },
    {
      "name": "Google API Key",
      "pattern": "AIza[0-9A-Za-z\\-_]{35}",
      "severity": 5
    },
    {
      "name": "GitHub Token",
      "pattern": "gh[pousr]_[A-Za-z0-9_]{36,255}",
      "severity": 5
    },
    {
      "name": "GitLab Token",
      "pattern": "glpat-[A-Za-z0-9\\-_]{20,}",
      "severity": 5
    },
    {
      "name": "Slack Token",
      "pattern": "xox[baprs]-[0-9]{10,13}-[0-9]{10,13}[a-zA-Z0-9-]*",
      "severity": 5
    },
    {
      "name": "Stripe API Key",
      "pattern": "sk_live_[0-9a-zA-Z]{24,}",
      "severity": 5
    },
    {
      "name": "OpenAI API Key",
      "pattern": "sk-[A-Za-z0-9]{48}",
      "severity": 5
    },
    {
      "name": "Anthropic API Key",
      "pattern": "sk-ant-[A-Za-z0-9\\-_]{90,}",
      "severity": 5
    },
    {
      "name": "RSA Private Key",
      "pattern": "-----BEGIN RSA PRIVATE KEY-----",
      "severity": 5
    },
    {
      "name": "SSH Private Key",
      "pattern": "-----BEGIN OPENSSH PRIVATE KEY-----",
      "severity": 5
    },
    {
      "name": "Database Connection String",
      "pattern": "(?i)(mysql|postgres|mongodb|redis)://[^:]+:[^@]+@[^\\s]+",
      "severity": 5
    },
    {
      "name": "Password in Config",
      "pattern": "(?i)(password|passwd|pwd)\\s*[=:]\\s*['\"]?([^'\"\\s]{8,})['\"]?",
      "severity": 4
    },
    {
      "name": "API Key (Generic)",
      "pattern": "(?i)(api[_-]?key|apikey)\\s*[=:]\\s*['\"]?([A-Za-z0-9\\-_]{16,})['\"]?",
      "severity": 4
    },
    {
      "name": "JWT Token",
      "pattern": "eyJ[A-Za-z0-9-_]+\\.eyJ[A-Za-z0-9-_]+\\.[A-Za-z0-9-_]+",
      "severity": 4
    },
    {
      "name": "Social Security Number",
      "pattern": "\\b\\d{3}-\\d{2}-\\d{4}\\b",
      "severity": 5
    },
    {
      "name": "Credit Card Number",
      "pattern": "\\b(?:4[0-9]{12}(?:[0-9]{3})?|5[1-5][0-9]{14}|3[47][0-9]{13})\\b",
      "severity": 5
    }
  ]
}
