{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TurboMerger",
  "version": "7.5.0",
  "identifier": "com.turbomerger.app",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "TurboMerger",
        "width": 640,
        "height": 780,
        "minWidth": 500,
        "minHeight": 650,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src ipc: http://ipc.localhost; frame-src 'none'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "shortDescription": "One-click codebase merger",
    "longDescription": "TurboMerger merges a codebase into a single LLM-ready markdown file: gitignore-aware scanning, secret redaction, parallel processing, and a per-file merge report.",
    "category": "DeveloperTool",
    "publisher": "TurboMerger",
    "copyright": "Copyright 2026 TurboMerger Contributors"
  }
}
