{
  "version": "4.0.0",
  "scan_mode": "smart",
  "max_file_size_mb": 2.0,
  "max_chars_per_file": 100000,
  "skip_directories": [
    ".git",
    ".svn",
    ".hg",
    "node_modules",
    "vendor",
    "__pycache__",
    ".pytest_cache",
    "venv",
    ".venv",
    "build",
    "dist",
    ".next",
    ".nuxt"
  ],
  "skip_extensions": [
    ".exe",
    ".dll",
    ".so",
    ".dylib",
    ".pyc",
    ".pyo",
    ".class",
    ".zip",
    ".tar",
    ".gz",
    ".rar",
    ".7z",
    ".png",
    ".jpg",
    ".jpeg",
    ".gif",
    ".bmp",
    ".ico",
    ".svg",
    ".mp3",
    ".mp4",
    ".wav",
    ".avi",
    ".mov",
    ".pdf"
  ],
  "secret_files": [
    ".env",
    ".env.local",
    ".env.production",
    ".env.development",
    "id_rsa",
    "id_dsa",
    "id_ed25519",
    "credentials.json",
    "secrets.json",
    "service-account.json"
  ]
}
